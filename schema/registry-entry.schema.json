{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.org/lingputation/registry-entry.schema.json",
  "title": "Lingputation registry entry",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "registry_id",
    "codebook_id",
    "codebook_version",
    "title",
    "summary",
    "status",
    "authors",
    "codebook_path",
    "validation_records",
    "projectibility_profile",
    "tags",
    "license",
    "created",
    "updated"
  ],
  "properties": {
    "schema_version": {
      "const": "0.1.0"
    },
    "registry_id": {
      "$ref": "#/$defs/slug"
    },
    "codebook_id": {
      "$ref": "#/$defs/slug"
    },
    "codebook_version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+([-.][A-Za-z0-9.-]+)?$"
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "summary": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "enum": ["draft", "reviewed", "released", "deprecated"]
    },
    "authors": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/person"
      },
      "minItems": 1
    },
    "codebook_path": {
      "type": "string",
      "minLength": 1
    },
    "validation_records": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/validationRef"
      },
      "minItems": 1
    },
    "projectibility_profile": {
      "type": "object",
      "additionalProperties": false,
      "required": ["supported_inferences", "unsupported_inferences", "scope_conditions", "failure_zones"],
      "properties": {
        "supported_inferences": {
          "$ref": "#/$defs/nonemptyStringArray"
        },
        "unsupported_inferences": {
          "$ref": "#/$defs/nonemptyStringArray"
        },
        "scope_conditions": {
          "$ref": "#/$defs/nonemptyStringArray"
        },
        "failure_zones": {
          "$ref": "#/$defs/nonemptyStringArray"
        }
      }
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "links": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/link"
      }
    },
    "license": {
      "type": "string",
      "minLength": 1
    },
    "created": {
      "$ref": "#/$defs/date"
    },
    "updated": {
      "$ref": "#/$defs/date"
    }
  },
  "$defs": {
    "date": {
      "type": "string",
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}$"
    },
    "slug": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9-]*$"
    },
    "person": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name"],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "affiliation": {
          "type": "string"
        },
        "orcid": {
          "type": "string"
        }
      }
    },
    "validationRef": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "path", "status"],
      "properties": {
        "id": {
          "$ref": "#/$defs/slug"
        },
        "path": {
          "type": "string",
          "minLength": 1
        },
        "status": {
          "enum": ["template", "planned", "in_progress", "complete", "superseded"]
        }
      }
    },
    "link": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "url"],
      "properties": {
        "kind": {
          "enum": ["landing", "repository", "paper", "documentation", "other"]
        },
        "url": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "nonemptyStringArray": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "minItems": 1
    }
  }
}
